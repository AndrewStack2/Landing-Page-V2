@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="font-sans antialiased text-slate-600 bg-white min-h-screen" style="font-family: 'DM Sans', sans-serif;">
    @Body
</div>

@* ===== CAPA 5: GPS PIN CURSOR ===== *@
<div id="spider-cursor-dot" aria-hidden="true">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
         width="22" height="22" fill="white">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        <circle cx="12" cy="9" r="2.5" fill="#1364ED"/>
    </svg>
</div>
<div id="spider-cursor-ring" aria-hidden="true"></div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initCustomCursor"); // ✅ Cursor activo en TODAS las páginas
        }
    }
}
