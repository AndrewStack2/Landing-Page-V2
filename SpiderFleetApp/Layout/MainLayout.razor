@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="relative flex min-h-screen w-full flex-col bg-white text-slate-900 font-display antialiased selection:bg-primary selection:text-white overflow-x-hidden scroll-smooth">

    <NavbarMenu />
    <main class="flex-1 bg-white relative z-10 shadow-2xl pt-0">
        @Body
    </main>

    <StickyFooter />

    <a href="/#inicio"
       id="back-to-top"
       class="back-to-top-btn fixed right-6 z-50 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/40 transition-all hover:bg-blue-700 hover:scale-110 hover:shadow-[0_0_20px_rgba(19,100,237,0.5)] opacity-0 pointer-events-none translate-y-10 duration-500">
        <span class="material-symbols-outlined text-xl">arrow_upward</span>
    </a>

</div>

@* ===== GPS PIN CURSOR ===== *@
<div id="spider-cursor-dot" aria-hidden="true">
    <svg viewBox="0 0 52 80" xmlns="http://www.w3.org/2000/svg" width="28" height="44">
        <circle cx="26" cy="22" r="20" fill="#1364ED"/>
        <circle cx="19" cy="15" r="6" fill="rgba(255,255,255,0.25)"/>
        <circle cx="26" cy="22" r="5" fill="white"/>
        <line x1="26" y1="42" x2="26" y2="76"
              stroke="#4A5568" stroke-width="3.5"
              stroke-linecap="round"/>
    </svg>
</div>
@* Ring eliminado — no se necesita con el pushpin *@

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("handleBackToTopVisibility");
            await JS.InvokeVoidAsync("initCustomCursor"); // ✅ Mismo patrón que EmptyLayout
        }
    }
}