@page "/login"
<PageTitle>Iniciar Sesión | Spider Fleet</PageTitle>
@layout EmptyLayout
@inject NavigationManager Navigation

<div class="min-h-screen bg-white flex overflow-hidden font-sans text-slate-900" style="font-family: 'DM Sans', sans-serif;">

    @* === COLUMNA IZQUIERDA: Formulario === *@
    <main class="w-full lg:w-1/2 flex flex-col justify-center items-center p-6 sm:p-8 md:p-12 relative z-10 overflow-y-auto">
        
        <div class="w-full max-w-md space-y-6 my-auto pt-8 pb-8">
            
            @* Logo + Título *@
            <div class="text-center mb-8">
                <img src="Assets/logoazul.png" alt="SpiderFleet Logo" class="h-10 sm:h-10 mx-auto mb-6" />
                <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight">Bienvenido de nuevo</h2>
                <p class="text-sm sm:text-base text-slate-500 mt-2">Ingresa a tu panel de control</p>
            </div>

            @* Botones Sociales *@
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors text-sm font-semibold text-slate-700">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="h-5 w-5" alt="Google" />
                    Google
                </button>
                <button class="w-full flex items-center justify-center gap-2 px-4 py-2.5 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors text-sm font-semibold text-slate-700">
                    <img src="https://www.svgrepo.com/show/511330/apple-173.svg" class="h-5 w-5" alt="Apple" />
                    Apple
                </button>
            </div>

            <div class="relative flex items-center py-2 mb-6">
                <div class="flex-grow border-t border-slate-200"></div>
                <span class="flex-shrink-0 mx-4 text-slate-400 text-xs font-bold tracking-wider uppercase">O ingresa con tu email</span>
                <div class="flex-grow border-t border-slate-200"></div>
            </div>

            @* Formulario *@
            <div class="space-y-4 sm:space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email</label>
                    <div class="relative group">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">mail</span>
                        </span>
                        <input type="email" placeholder="correo@spiderfleet.com" class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-sm font-medium outline-none" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Contraseña</label>
                    <div class="relative group">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">lock</span>
                        </span>
                        <input @bind="password" type="@(showPassword ? "text" : "password")" placeholder="••••••••" class="w-full pl-11 pr-12 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-sm font-medium outline-none" />
                        <button type="button" @onclick="TogglePassword" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                            <span class="material-symbols-outlined text-xl">@(showPassword ? "visibility_off" : "visibility")</span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between pt-1 pb-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary/30" />
                        <span class="text-sm font-medium text-slate-600">Recordarme</span>
                    </label>
                    <a href="#" class="text-sm font-bold text-primary hover:text-blue-700 hover:underline transition-colors">¿Olvidaste tu contraseña?</a>
                </div>

                @* BOTÓN con animación neobrutalist press adaptada a Spider Fleet *@
               <button type="button" class="w-full py-3.5 px-6 rounded-xl bg-primary text-white font-bold text-sm tracking-wide flex items-center justify-center gap-2 border-2 border-blue-800 shadow-[4px_4px_0px_0px_rgba(30,58,138,0.8)] hover:shadow-[1px_1px_0px_0px_rgba(30,58,138,0.8)] hover:translate-x-[3px] hover:translate-y-[3px] active:shadow-none active:translate-x-[4px] active:translate-y-[4px] transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-blue-400 [touch-action:manipulation]">
                   <span>Entrar a mi panel</span>
                   <span class="material-symbols-outlined text-lg">arrow_forward</span>
               </button>
            </div>

            <p class="text-center text-sm font-medium text-slate-500 pt-8">
                ¿No tienes cuenta? <a href="/signup" class="text-primary font-bold hover:underline transition-colors">Regístrate aquí</a>
            </p>
            
            <div class="text-center pt-6">
                <a href="/" class="text-sm font-semibold text-slate-400 hover:text-slate-700 transition-colors inline-flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">arrow_back</span> Volver a Spider Fleet
                </a>
            </div>
        </div>
    </main>

    @* === COLUMNA DERECHA: Globo === *@
    <aside class="hidden lg:flex w-1/2 bg-[#1364ed] flex-col justify-center items-center relative overflow-hidden">
        
        <div class="relative z-20 text-center mb-12 px-12">
            <h2 class="text-4xl font-extrabold text-white tracking-tight mb-4">Conectando tu logística.</h2>
            <p class="text-blue-100 text-lg max-w-md mx-auto">Visibilidad total y rastreo GPS en vivo para que nunca pierdas el control de tu operación.</p>
        </div>

        <div class="relative w-[450px] h-[450px] z-10 flex items-center justify-center">
            <div class="absolute inset-0 bg-blue-400/30 rounded-full blur-[80px]"></div>
            
            <div class="css-globe-container">
                <img src="Assets/world.svg" alt="World Map" class="globe-map" />

                <div class="globe-pin" style="top: 48%; left: 25%;">
                    <div class="pin-pulse"></div>
                    <div class="pin-dot"></div>
                </div>
                <div class="globe-pin" style="top: 36%; left: 15%;">
                    <div class="pin-pulse" style="animation-delay: 1s;"></div>
                    <div class="pin-dot"></div>
                </div>
                <div class="globe-pin" style="top: 62%; left: 25%;">
                    <div class="pin-pulse" style="animation-delay: 0.5s;"></div>
                    <div class="pin-dot"></div>
                </div>
            </div>
        </div>
        
    </aside>
</div>

@code {
    private string password = "";
    private bool showPassword = false;

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }
}
