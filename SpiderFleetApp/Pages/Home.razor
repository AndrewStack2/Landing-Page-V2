@* Home.razor *@
@page "/"
<PageTitle>Spider Fleet — Inteligencia de Flota para México</PageTitle>

@using SpiderFleetApp.Pages.Components

@* 1. THE HOOK *@
<Hero />

@* 2. THE PAIN *@
<PainVsDream />

@* 3. THE FIX *@
<FeaturesMode />

@* 4. THE PROOF (Visual) *@
<VideoFeature />

@* 5. THE PROOF (Social) *@
<TestimonialsGrid />

@* 6. OBJECTIONS *@
<FAQ />

@* 7. CLIMAX *@
<CtaBannerFinal />

@code {
    [Inject] IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(300);
            await JS.InvokeVoidAsync("initScrollAnimations");
            await JS.InvokeVoidAsync("initCountUp");
            await JS.InvokeVoidAsync("initMagneticButtons");
        }
    }
}