                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Digital</p>
                            <p class="text-xl font-bold text-slate-900">Carpeta Digital</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
