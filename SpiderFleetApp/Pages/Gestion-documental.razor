@page "/gestion-documental"
<PageTitle>Gestión Documental Vehicular Digital | Spider Fleet</PageTitle>
<HeadContent>
    <meta name="description" content="Digitaliza toda la papelería de tu flota: licencias, seguros, permisos y verificaciones. Alertas de vencimiento y acceso desde cualquier dispositivo. Spider Fleet México." />
    <link rel="canonical" href="https://spiderfleet.mx/gestion-documental" />
    <meta property="og:title" content="Gestión Documental Vehicular Digital | Spider Fleet" />
    <meta property="og:description" content="Digitaliza licencias, seguros y permisos de tu flota con alertas de vencimiento automáticas." />
    <meta property="og:url" content="https://spiderfleet.mx/gestion-documental" />
</HeadContent>

<style>
    .feature-card {
        min-height: 260px;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    border-color 0.4s ease;
    }
    .feature-card:hover {
        transform: translateY(-6px);
    }

    .feature-card .card-body {
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        opacity: 1;
        transform: translateY(0);
    }

    @@media (min-width: 768px) and (hover: hover) and (pointer: fine) {
        .feature-card .card-body {
            opacity: 0;
            transform: translateY(16px);
        }
        .feature-card:hover .card-body {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .feature-card .card-top-line {
        opacity: 0;
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .feature-card:hover .card-top-line {
        opacity: 1;
    }

    .feature-card .card-icon-b {
        background-color: #eff6ff;
        color: #2563eb;
        transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    color 0.4s ease,
                    transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .feature-card:hover .card-icon-b {
        transform: scale(1.1);
    }
</style>

@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div class="bg-white">

    <!-- ═══════════════════════════════════════
         HERO SECTION
    ═══════════════════════════════════════ -->
    <section class="relative overflow-hidden pt-20 pb-16 md:pt-32 md:pb-32">
