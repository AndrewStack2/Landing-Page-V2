@code {
    private bool IsPersonalMode { get; set; } = true;

    private void SetMode(bool personal) => IsPersonalMode = personal;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }

    private string SliderStyle  => IsPersonalMode ? "transform:translateX(0)"    : "transform:translateX(100%)";
    private string BtnPersonal  => IsPersonalMode ? "text-indigo-600 font-bold"  : "text-slate-500 font-semibold";
    private string BtnEmpresa   => IsPersonalMode ? "text-slate-500 font-semibold" : "text-primary font-bold";
    private string ShowPersonal => IsPersonalMode ? "block" : "hidden";
    private string ShowEmpresa  => IsPersonalMode ? "hidden" : "block";
}
