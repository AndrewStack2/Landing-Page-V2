@code {
    private bool IsPersonalMode { get; set; } = true;

    private void SetMode(bool isPersonal)
    {
        IsPersonalMode = isPersonal;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initializeCarouselDrag");
        }
    }
}
