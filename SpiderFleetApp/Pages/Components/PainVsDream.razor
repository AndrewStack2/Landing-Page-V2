@inject IJSRuntime JS

<section class="bg-slate-50 py-24 relative overflow-hidden border-t border-slate-100">
    <div class="mx-auto max-w-7xl px-6 relative z-10">
        
        @* Header & Toggle *@
        <div class="text-center mb-16 scroll-animate">
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 transition-all duration-300">
                @(IsPersonalMode ? "No dejes la seguridad de tu auto al azar." : "La logística no debería ser un caos.")
            </h2>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto transition-all duration-300">
                @(IsPersonalMode 
                    ? "La tranquilidad de saber dónde está tu vehículo y tener el control total, sin depender de alarmas tradicionales." 
                    : "Decirle adiós a los procesos manuales y hojas de cálculo es el primer paso para hacer crecer tu operación.")
            </p>

            <div class="flex justify-center mt-8">
                <div class="bg-white p-1.5 rounded-full flex relative isolate border border-slate-200 shadow-sm w-full max-w-[340px]">
                    <div class="absolute left-1.5 top-1.5 bottom-1.5 w-[calc(50%-6px)] bg-slate-100 rounded-full transition-transform duration-300 z-0"
                         style='transform: translateX(@(IsPersonalMode ? "0" : "100%"));'></div>
                         
                    <button class="flex-1 relative z-10 py-2.5 text-sm transition-colors duration-300 @(IsPersonalMode ? "text-[#0d6efd] font-bold" : "text-slate-500 font-medium")"
                            @onclick="() => SetMode(true)">Uso Personal</button>
                    <button class="flex-1 relative z-10 py-2.5 text-sm transition-colors duration-300 @(IsPersonalMode ? "text-slate-500 font-medium" : "text-primary font-bold")"
                            @onclick="() => SetMode(false)">Para Empresas</button>
                </div>
            </div>
        </div>

        @* ==========================================
           MODO PERSONAL (Dolor + Solución)
           ========================================== *@
        <div class="@(IsPersonalMode ? "grid" : "hidden") md:grid-cols-2 gap-8 items-stretch">
            
            @* THE OLD WAY *@
            <div class="bg-white border border-slate-200 rounded-3xl p-8 sm:p-12 scroll-animate delay-100 relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-full h-1 bg-red-400"></div>
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-500">
                        <span class="material-symbols-outlined">close</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900">La inseguridad tradicional</h3>
                </div>
                <ul class="space-y-5 text-slate-600">
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Miedo constante al dejar tu auto estacionado en la calle.</span>
                    </li>
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Alarmas ruidosas que los ladrones ya saben desactivar.</span>
                    </li>
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Preocupación cuando prestas el auto a familiares.</span>
                    </li>
                </ul>
                <div class="mt-8 p-4 bg-slate-50 border border-red-100 rounded-xl shadow-sm opacity-60 grayscale">
                    <div class="h-2 w-full bg-slate-200 rounded mb-2"></div>
                    <div class="h-2 w-3/4 bg-slate-200 rounded mb-2"></div>
                    <div class="h-2 w-5/6 bg-slate-200 rounded"></div>
                    <div class="mt-4 text-[10px] text-red-500 font-bold font-mono">ALERTA: VEHÍCULO VULNERABLE</div>
                </div>
            </div>

            @* THE SPIDERFLEET WAY *@
            <div class="bg-indigo-50 border border-indigo-100 rounded-3xl p-8 sm:p-12 scroll-animate delay-200 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-[#0d6efd]"></div>
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full text-white shadow-lg bg-[#0d6efd] shadow-indigo-500/30">
                        <span class="material-symbols-outlined">check</span>
                    </div>
                    <h3 class="text-xl font-bold text-indigo-950">Con SpiderFleet</h3>
                </div>
                <ul class="space-y-5 text-indigo-900">
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-[#0d6efd] mt-0.5 text-xl">check_circle</span>
                        <span>Conoce la ubicación exacta de tu auto desde tu celular 24/7.</span>
                    </li>
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-[#0d6efd] mt-0.5 text-xl">check_circle</span>
                        <span>Corte de motor a distancia en caso de robo o emergencia.</span>
                    </li>
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-[#0d6efd] mt-0.5 text-xl">check_circle</span>
                        <span>Alertas al instante si el auto se mueve sin tu permiso.</span>
                    </li>
                </ul>
                <div class="mt-8 p-4 bg-white border border-blue-200 rounded-xl shadow-lg relative">
                    <div class="flex justify-between items-center mb-3">
                        <div class="h-2 w-1/3 bg-blue-100 rounded"></div>
                        <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded">Protegido</span>
                    </div>
                    <div class="h-10 w-full bg-slate-50 rounded border border-slate-100 flex items-center px-3">
                        <div class="h-2 w-2 bg-green-500 rounded-full mr-2 animate-pulse"></div>
                        <span class="text-xs text-slate-600 font-mono">Auto conectado y seguro</span>
                    </div>
                </div>
            </div>
        </div>

        @* ==========================================
           MODO EMPRESA (Dolor + Solución)
           ========================================== *@
        <div class="@(!IsPersonalMode ? "grid" : "hidden") md:grid-cols-2 gap-8 items-stretch">
            
            @* THE OLD WAY *@
            <div class="bg-white border border-slate-200 rounded-3xl p-8 sm:p-12 scroll-animate delay-100 relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-full h-1 bg-red-400"></div>
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-500">
                        <span class="material-symbols-outlined">close</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900">La vieja manera</h3>
                </div>
                <ul class="space-y-5 text-slate-600">
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Llamar a los choferes para saber dónde están.</span>
                    </li>
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Hojas de Excel desordenadas para el mantenimiento.</span>
                    </li>
                    <li class="flex items-start gap-3 opacity-80">
                        <span class="material-symbols-outlined text-red-400 mt-0.5 text-xl">cancel</span>
                        <span>Multas por documentos y seguros vencidos.</span>
                    </li>
                </ul>
                <div class="mt-8 p-4 bg-slate-50 border border-red-100 rounded-xl shadow-sm opacity-60 grayscale">
                    <div class="h-2 w-full bg-slate-200 rounded mb-2"></div>
                    <div class="h-2 w-3/4 bg-slate-200 rounded mb-2"></div>
                    <div class="h-2 w-5/6 bg-slate-200 rounded"></div>
                    <div class="mt-4 text-[10px] text-red-500 font-bold font-mono">ERROR: ACTUALIZACIÓN MANUAL REQUERIDA</div>
                </div>
            </div>

            @* THE SPIDERFLEET WAY *@
            <div class="bg-blue-50 border border-blue-100 rounded-3xl p-8 sm:p-12 scroll-animate delay-200 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-primary"></div>
                <div class="mb-6 flex items-center gap-3">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full text-white shadow-lg bg-primary shadow-blue-500/30">
                        <span class="material-symbols-outlined">check</span>
                    </div>
                    <h3 class="text-xl font-bold text-blue-950">Con SpiderFleet</h3>
                </div>
                <ul class="space-y-5 text-blue-900">
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-primary mt-0.5 text-xl">check_circle</span>
                        <span>Visualiza toda tu flota en vivo en un mapa interactivo.</span>
                    </li>
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-primary mt-0.5 text-xl">check_circle</span>
                        <span>Dashboard centralizado de gastos e inspecciones.</span>
                    </li>
                    <li class="flex items-start gap-3 font-medium">
                        <span class="material-symbols-outlined text-primary mt-0.5 text-xl">check_circle</span>
                        <span>Alertas automáticas antes de que caduquen las pólizas.</span>
                    </li>
                </ul>
                <div class="mt-8 p-4 bg-white border border-blue-200 rounded-xl shadow-lg relative">
                    <div class="flex justify-between items-center mb-3">
                        <div class="h-2 w-1/3 bg-blue-100 rounded"></div>
                        <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded">Protegido</span>
                    </div>
                    <div class="h-10 w-full bg-slate-50 rounded border border-slate-100 flex items-center px-3">
                        <div class="h-2 w-2 bg-green-500 rounded-full mr-2 animate-pulse"></div>
                        <span class="text-xs text-slate-600 font-mono">Unidad A-101 operativa</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@code {
    private bool IsPersonalMode { get; set; } = false;

    private async Task SetMode(bool isPersonal)
    {
        IsPersonalMode = isPersonal;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("initScrollAnimations");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}
