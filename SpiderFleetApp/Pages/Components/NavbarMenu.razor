@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<style>
    .mob-trigger {
        position: relative;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(90px) saturate(190%);
        -webkit-backdrop-filter: blur(90px) saturate(190%);
        border: 1.5px solid rgba(209,219,234,0.90);
        box-shadow: 0 6px 28px rgba(0,0,0,0.11), 0 1px 5px rgba(0,0,0,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 61;
        color: #1364ed;
        outline: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .mob-trigger:hover  { transform: scale(1.07); box-shadow: 0 10px 32px rgba(19,100,237,0.20); }
    .mob-trigger:active { transform: scale(0.93); }

    .mob-trigger-icon {
        font-size: 24px;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.32s cubic-bezier(0.34,1.56,0.64,1);
    }

    .mob-item {
        position: absolute;
        top: 0;
        left: 0;
        width: 64px;
        height: 64px;
        border-radius: 32px;
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1.5px solid rgba(209,219,234,0.88);
        box-shadow: 0 4px 18px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        padding-left: 0;
        text-decoration: none;
        color: #475569;
        cursor: pointer;
        overflow: hidden;
        white-space: nowrap;
        will-change: transform, opacity, width;
        transition:
            transform      320ms cubic-bezier(0.4,0,0.2,1),
            opacity        320ms,
            width          380ms cubic-bezier(0.34,1.25,0.64,1),
            border-radius  380ms ease,
            padding-left   380ms ease,
            gap            380ms ease,
            background     0.15s ease,
            color          0.15s ease,
            box-shadow     0.15s ease;
        backface-visibility: hidden;
    }
    .mob-item:hover {
        background: rgba(239,246,255,0.96);
        color: #1364ed;
        box-shadow: 0 6px 22px rgba(19,100,237,0.12);
    }
    .mob-item.mob-sub {
        background: rgba(239,246,255,0.88);
        border-color: rgba(147,197,253,0.55);
    }
    .mob-item.mob-sub:hover {
        background: rgba(219,234,254,0.98);
        box-shadow: 0 6px 22px rgba(19,100,237,0.16);
    }
    .mob-stack-open .mob-item {
        width: 220px;
        border-radius: 32px;
        justify-content: flex-start;
        padding-left: 20px;
        gap: 13px;
    }
    .mob-label {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: #1e293b;
        opacity: 0;
        transform: translateX(-10px);
        transition: opacity 0.24s ease, transform 0.24s ease;
        pointer-events: none;
        user-select: none;
        line-height: 1.2;
    }
    .mob-stack-open .mob-label {
        opacity: 1;
        transform: translateX(0);
    }
    .mob-item.mob-sub .mob-label {
        font-size: 12.5px;
        color: #1d4ed8;
        font-weight: 600;
    }
    .mob-badge {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 19px;
        height: 19px;
        background: #1364ed;
        border-radius: 50%;
        border: 2px solid white;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
        transition: transform 0.28s ease;
        flex-shrink: 0;
    }
    .mob-badge.rotated { transform: rotate(180deg); }
    .mob-stack-open .mob-badge {
        position: relative;
        bottom: auto;
        right: auto;
        margin-left: auto;
        margin-right: 14px;
        border-color: rgba(226,232,240,0.50);
    }
    .mob-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.20);
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
        z-index: 45;
        transition: opacity 0.3s ease;
    }
    .mob-stack {
        position: fixed;
        top: 20px;
        left: 20px;
        width: 64px;
        z-index: 60;
        overflow: visible;
        transition:
            width  380ms cubic-bezier(0.34,1.25,0.64,1),
            height 380ms cubic-bezier(0.4,0,0.2,1);
    }
    .mob-stack-open {
        width: 224px;
    }
    .nav-pill {
        transition:
            max-width        400ms cubic-bezier(0.4,0,0.2,1),
            padding-left     400ms cubic-bezier(0.4,0,0.2,1),
            padding-right    400ms cubic-bezier(0.4,0,0.2,1),
            padding-top      400ms cubic-bezier(0.4,0,0.2,1),
            padding-bottom   400ms cubic-bezier(0.4,0,0.2,1),
            box-shadow       400ms ease,
            background-color 400ms ease,
            border-color     400ms ease,
            top              400ms cubic-bezier(0.4,0,0.2,1);
    }
    .nav-container {
        transition: top 400ms cubic-bezier(0.4,0,0.2,1);
    }
</style>

@* ── DESKTOP NAVBAR (hidden on mobile) ── *@
<div class="hidden md:flex fixed left-0 w-full z-50 justify-center nav-container"
     style="top: @NavContainerTop;">
    <nav class="nav-pill inline-flex items-center rounded-full
                bg-white/60 dark:bg-black/70
                backdrop-blur-2xl backdrop-saturate-[180%] backdrop-brightness-110
                border border-white/40 dark:border-white/10
                relative overflow-visible w-fit"
         style="@NavPillStyle">

        <div class="flex items-center gap-6">
            <a href="/" class="flex items-center group">
                <img src="Assets/favicon.png" alt="Spider Logo"
                     class="h-[35px] w-[35px] transition-transform group-hover:scale-110" />
            </a>

            <ul class="menu-list flex items-center gap-1">
                @foreach (var item in MenuItems)
                {
                    <li class="menu-item"
                        @onmouseenter="() => HandleMouseEnter(item.Id)"
                        @onmouseleave="() => HandleMouseLeave(item.Id)">

                        <div class="flip-container cursor-pointer"
                             @onclick="() => HandleItemClick(item)">
                            <div class="@GlowClass(item.Id)" style="background: @item.Gradient;"></div>
                            <div class="@FlipClass(item.Id)">
                                <div class="face face-front group">
                                    <span class="@LabelClass(item.Id)">@item.Label</span>
                                </div>
                                <div class="face face-back group">
                                    <span class="label-text font-medium text-sm text-slate-900 dark:text-white">
                                        @item.Label
                                    </span>
                                </div>
                            </div>
                        </div>

                        @if (item.Id == "productos")
                        {
                            <div class="@DropdownClass()"
                                 @onmouseenter='() => HandleMouseEnter("productos")'
                                 @onmouseleave='() => HandleMouseLeave("productos")'>
                                <div class="flex flex-col gap-2 p-3 min-w-[340px]">
                                    <NavbarProductItem
                                        Title="Rastreo GPS"
                                        Description="Monitoreo de alta precisión segundo a segundo."
                                        Href="/rastreo-gps"
                                        ImageSrc="Assets/GPS.jpg" />
                                    <NavbarProductItem
                                        Title="Optimización de Rutas"
                                        Description="Reduce costos y tiempos de entrega con IA."
                                        Href="/optimizacion-rutas"
                                        ImageSrc="Assets/Optimization route.jpg" />
                                    <NavbarProductItem
                                        Title="Mantenimiento"
                                        Description="Gestión preventiva para alargar la vida de tus unidades."
                                        Href="/mantenimiento"
                                        ImageSrc="Assets/Mantenimiento.jpg" />
                                    <NavbarProductItem
                                        Title="Gestión Documental"
                                        Description="Toda la papelería de tu vehículo, digitalizada."
                                        Href="/gestion-documental"
                                        ImageSrc="Assets/Files.jpg" />
                                </div>
                            </div>
                        }
                    </li>
                }
            </ul>
        </div>

        <div class="border-l border-slate-200 dark:border-slate-800 flex items-center gap-4"
             style="@NavActionsStyle">
            <a href="/login"
               class="text-sm font-bold text-slate-900 dark:text-white hover:text-primary transition-colors whitespace-nowrap">
                Iniciar sesión
            </a>
            <a href="/signup"
               class="rounded-full bg-primary text-white font-bold shadow-lg shadow-primary/20
                      transition-all hover:bg-blue-600 hover:scale-105 active:scale-95 whitespace-nowrap"
               style="@NavCtaStyle">
                Empieza Gratis Ahora
            </a>
        </div>
    </nav>
</div>

@* ── MOBILE DOCK (hidden on desktop) ── *@
<div class="md:hidden">

