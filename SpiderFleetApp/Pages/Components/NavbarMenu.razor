@implements IDisposable

@code {
    // ── Scroll state ────────────────────────────────────────
    private bool   IsScrolled   { get; set; } = false;
    private double _lastScrollY = 0;
    private DotNetObjectReference<NavbarMenu>? _dotNetRef;

    private string NavContainerTop => IsScrolled ? "16px" : "24px";

    private string NavPillStyle => IsScrolled
        ? "max-width:88vw; padding-left:1.25rem; padding-right:1.25rem; padding-top:0.375rem; padding-bottom:0.375rem; box-shadow:0 8px 32px rgba(0,0,0,0.13),0 1.5px 6px rgba(0,0,0,0.07);"
        : "max-width:95vw; padding-left:1.5rem;  padding-right:1.5rem;  padding-top:0.5rem;   padding-bottom:0.5rem;   box-shadow:0 4px 24px rgba(0,0,0,0.09),0 1px 4px rgba(0,0,0,0.05);";

    private string NavActionsStyle => IsScrolled
        ? "margin-left:1.25rem; padding-left:1.25rem; gap:0.75rem;"
        : "margin-left:1.5rem;  padding-left:1.5rem;  gap:1rem;";

    private string NavCtaStyle => IsScrolled
        ? "font-size:0.7rem; padding-left:1.1rem; padding-right:1.1rem; padding-top:0.5rem; padding-bottom:0.5rem;"
        : "font-size:0.75rem; padding-left:1.5rem;  padding-right:1.5rem;  padding-top:0.625rem; padding-bottom:0.625rem;";

    [JSInvokable]
    public void OnScrollChanged(double scrollY)
    {
        var wasScrolled = IsScrolled;
        IsScrolled   = scrollY > 10;
        _lastScrollY = scrollY;
        if (wasScrolled != IsScrolled)
            StateHasChanged();
    }

    // ── Desktop state ───────────────────────────────────────
    private string? hoveredItem;
    private bool isProductosPersistent;
    private System.Threading.CancellationTokenSource? mouseLeaveCts;

    private string GlowClass(string id)  => IsActive(id) ? "glow active" : "glow";
    private string FlipClass(string id)  => IsActive(id) ? "flip-card active" : "flip-card";
    private string LabelClass(string id) => IsActive(id)
        ? "label-text font-bold text-sm text-slate-900 dark:text-white"
        : "label-text font-bold text-sm text-slate-900 dark:text-slate-100";
    private string DropdownClass() => IsActive("productos") ? "dropdown-panel active" : "dropdown-panel";

    // ── Mobile state ────────────────────────────────────────
    private bool IsMobileOpen          { get; set; } = false;
    private bool IsMobileProductosOpen { get; set; } = false;

    private void ToggleMobileMenu()
    {
        IsMobileOpen = !IsMobileOpen;
        if (!IsMobileOpen) IsMobileProductosOpen = false;
    }

    // ✅ FIX: CloseMobileMenu con su cuerpo correctamente cerrado
    private void CloseMobileMenu()
    {
        IsMobileOpen          = false;
        IsMobileProductosOpen = false;
    }

    private void ToggleProductosMobile() => IsMobileProductosOpen = !IsMobileProductosOpen;

    // ✅ FIX: IsCurrentPage como método independiente, después de CloseMobileMenu
    private bool IsCurrentPage(string path)
    {
        return NavigationManager.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase)
            || (path == "/" && NavigationManager.Uri == NavigationManager.BaseUri);
    }

    // ── Lifecycle ───────────────────────────────────────────
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("SpiderFleet.registerScrollListener", _dotNetRef);
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        hoveredItem           = null;
        isProductosPersistent = false;
        IsMobileOpen          = false;
        IsMobileProductosOpen = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
        _dotNetRef?.Dispose();
    }

    // ── Desktop handlers ────────────────────────────────────
    private void HandleMouseEnter(string id)
    {
        mouseLeaveCts?.Cancel();
        hoveredItem = id;
    }

    private async Task HandleMouseLeave(string id)
    {
        if (isProductosPersistent && id == "productos") return;
        mouseLeaveCts?.Cancel();
        mouseLeaveCts = new();
        var token = mouseLeaveCts.Token;
        try
        {
            await Task.Delay(300, token);
            if (!token.IsCancellationRequested)
            {
                hoveredItem           = null;
                isProductosPersistent = false;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleItemClick(MenuItem item)
    {
        if (item.Id == "productos")
        {
            isProductosPersistent = !isProductosPersistent;
            if (isProductosPersistent) hoveredItem = "productos";
        }
        else NavigationManager.NavigateTo(item.Href);
    }

    private bool IsActive(string id) =>
        hoveredItem == id || (id == "productos" && isProductosPersistent);

    // ── Data ────────────────────────────────────────────────
    private List<MenuItem> MenuItems = new()
    {
        new("productos", "Productos",       "#",                 "grid_view",          "radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(37,99,235,0.15) 50%, rgba(29,78,216,0) 100%)", "text-blue-500"),
        new("caract",    "Características", "/#caracteristicas", "featured_play_list", "radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(37,99,235,0.15) 50%, rgba(29,78,216,0) 100%)", "text-blue-500"),
        new("demo",      "Casos de Éxito",  "/#demo",            "verified",           "radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(37,99,235,0.15) 50%, rgba(29,78,216,0) 100%)", "text-blue-500"),
        new("precios",   "Precios",         "/precios",          "payments",           "radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(37,99,235,0.15) 50%, rgba(29,78,216,0) 100%)", "text-blue-500"),
        new("contacto",  "Contacto",        "/contacto",         "alternate_email",    "radial-gradient(circle, rgba(59,130,246,0.3) 0%, rgba(37,99,235,0.15) 50%, rgba(29,78,216,0) 100%)", "text-blue-500"),
    };

    public record MenuItem(string Id, string Label, string Href, string Icon, string Gradient, string IconColor);
    public record MobileItem(string Id, string Label, string Icon, string Href);
    public record SubProduct(string Label, string Icon, string Href);
}
