@namespace SpiderFleetApp.Pages.Components

<a href="@Href" class="flex items-center gap-4 p-4 rounded-2xl transition-all hover:bg-slate-50 group/item w-full">
    <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-xl bg-slate-100 shadow-lg border border-slate-200">
        <img src="@ImageSrc" alt="@Title" class="h-full w-full object-cover transition-transform duration-500 group-hover/item:scale-110" />
    </div>
    <div class="flex-1 flex flex-col justify-center">
        <h4 class="text-sm font-bold text-slate-900 group-hover/item:text-primary transition-colors mb-0.5">@Title</h4>
        <p class="text-[11px] leading-relaxed text-slate-500 line-clamp-2">@Description</p>
    </div>
</a>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public string ImageSrc { get; set; } = "";
}
