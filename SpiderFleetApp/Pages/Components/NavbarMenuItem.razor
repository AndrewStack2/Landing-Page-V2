@namespace SpiderFleetApp.Pages.Components

<div class="relative py-2 group/menu" @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave">
    <p class="cursor-pointer text-sm font-semibold text-slate-600 transition-colors hover:text-primary @(IsActive ? "text-primary" : "")">
        @Label
    </p>
    
    <div class="absolute top-[calc(100%+0.5rem)] left-1/2 -translate-x-1/2 pt-4 z-[100] transition-all duration-300 @(IsActive ? "opacity-100 visible translate-y-0 scale-100" : "opacity-0 invisible translate-y-2 scale-95")">
        <div class="bg-white/90 backdrop-blur-xl rounded-3xl overflow-hidden border border-slate-200 shadow-2xl p-4 transition-spring @DropdownClass">
             @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string DropdownClass { get; set; } = "w-max";
    [Parameter] public RenderFragment? ChildContent {get; set;}
    [Parameter] public EventCallback<string?> OnActiveChanged {get; set;}
    [Parameter] public string? ActiveItem {get; set;}

    private bool IsActive => ActiveItem == Label;

    private async Task HandleMouseEnter()
    {
        await OnActiveChanged.InvokeAsync(Label);
    }

    private async Task HandleMouseLeave()
    {
        // Handled by the parent Menu component for better UX, 
        // but we can add a small delay if needed.
    }
}
