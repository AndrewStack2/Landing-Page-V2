@page "/rastreo-gps"
<PageTitle>Rastreo GPS en Tiempo Real para Flotas | Spider Fleet</PageTitle>
<HeadContent>
    <meta name="description" content="Monitorea tu flota segundo a segundo con rastreo GPS de alta precisión. Geocercas inteligentes, alertas de desvío y protección antirrobo. Spider Fleet México." />
    <link rel="canonical" href="https://spiderfleet.mx/rastreo-gps" />
    <meta property="og:title" content="Rastreo GPS en Tiempo Real para Flotas | Spider Fleet" />
    <meta property="og:description" content="Monitoreo GPS de alta precisión, geocercas y alertas de desvío para tu flota en México." />
    <meta property="og:url" content="https://spiderfleet.mx/rastreo-gps" />
</HeadContent>
<style>
    .feature-card {
    min-height: 280px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s ease;
}
.feature-card:hover {
    transform: translateY(-6px);
}
.feature-card .card-body {
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 1;
    transform: translateY(0);
}
@@media (min-width: 768px) {
    .feature-card .card-body {
        opacity: 0;
        transform: translateY(16px);
    }
    .feature-card:hover .card-body {
        opacity: 1;
        transform: translateY(0);
    }
}
.feature-card .card-top-line {
    opacity: 0;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.feature-card:hover .card-top-line {
    opacity: 1;
}
.feature-card .card-icon-b {
    background-color: #eff6ff;
    color: #2563eb;
    transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.4s ease,
                transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.feature-card:hover .card-icon-b {
    background-color: #2563eb;
    color: white;
    transform: scale(1.1);
}
</style>
@inject IJSRuntime JS
@inject NavigationManager NavigationManager


<div class="bg-white">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-24 pb-20 md:pt-32 md:pb-32 bg-slate-50">
        <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:24px_24px] opacity-40"></div>
        <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-primary/5 blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-primary/5 blur-3xl"></div>

        <div class="mx-auto max-w-7xl px-6 relative z-10 text-center">
            <div class="inline-flex items-center rounded-full border border-primary/20 bg-white px-4 py-1.5 text-sm font-semibold text-primary shadow-sm mb-8 scroll-animate">
                <span class="mr-2 h-2 w-2 rounded-full bg-primary animate-pulse"></span>
                Tecnología de precisión
            </div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-7xl mb-6 scroll-animate delay-100">
                Tu vehículo bajo control,<br /><span class="text-primary">segundo a segundo.</span>
            </h1>
            <p class="mx-auto max-w-2xl text-lg text-slate-600 md:text-xl leading-relaxed mb-10 scroll-animate delay-200">
                Seguridad para tu familia o inteligencia operativa para tu flota. Rastreo GPS de alta precisión con cobertura nacional.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-animate delay-300">
                <button @onclick='() => NavigationManager.NavigateTo("/signup")' class="w-full sm:w-auto rounded-full bg-primary px-10 py-4 text-base font-bold text-white shadow-lg shadow-primary/25 transition-all hover:bg-blue-700 hover:scale-105 active:scale-95 group relative overflow-hidden">
                    <span class="relative z-10">Empieza Gratis Ahora</span>
                    <div class="absolute inset-0 -translate-x-full group-hover:animate-[shimmer_1s_infinite] bg-gradient-to-r from-transparent via-white/20 to-transparent z-0"></div>
                </button>
                <a href="#funcionalidades" class="w-full sm:w-auto rounded-full border border-slate-300 bg-white px-10 py-4 text-base font-bold text-slate-700 transition-all hover:bg-slate-50 hover:border-primary hover:text-primary">
                    Ver funcionalidades
                </a>
            </div>
        </div>
    </section>

    <!-- Benefits Toggle Section -->
    <section class="py-24 bg-white">
        <div class="mx-auto max-w-7xl px-6">
            <div class="text-center mb-12 scroll-animate">
                <h2 class="text-3xl font-extrabold text-slate-900 md:text-4xl">La herramienta que se adapta a ti</h2>
            </div>

            <div class="flex justify-center mb-16 scroll-animate delay-100">
                <div class="bg-slate-100 p-1.5 rounded-full flex relative isolate border border-slate-200 shadow-inner w-full max-w-[340px]">
                    <div class="absolute left-1.5 top-1.5 bottom-1.5 w-[calc(50%-6px)] bg-white rounded-full shadow transition-all duration-300 ease-in-out z-0 border border-slate-200" style="transform: translateX(@(IsPersonalMode ? "0" : "100%"));"></div>
                    <button class="flex-1 relative z-10 py-2.5 rounded-full text-sm transition-colors duration-300 text-center @(IsPersonalMode ? "text-primary font-bold" : "text-slate-500 font-semibold hover:text-slate-800")" @onclick="() => SetMode(true)">
                        Uso Personal
                    </button>
                    <button class="flex-1 relative z-10 py-2.5 rounded-full text-sm transition-colors duration-300 text-center @(IsPersonalMode ? "text-slate-500 font-semibold hover:text-slate-800" : "text-primary font-bold")" @onclick="() => SetMode(false)">
                        Para Empresas
                    </button>
                </div>
            </div>

            <!-- MODO PERSONAL — 3 cards (siempre en DOM, visibilidad por CSS) -->
            <div class="@(IsPersonalMode ? "grid" : "hidden") gap-6 md:grid-cols-3">
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-100 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">shield</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Familia</p>
                        <p class="text-xl font-bold text-slate-900">Seguridad Familiar</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Protege a los tuyos sabiendo siempre dónde se encuentra su vehículo en tiempo real.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-200 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">notification_important</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Seguridad</p>
                        <p class="text-xl font-bold text-slate-900">Alertas Anti-robo</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Recibe notificaciones inmediatas si tu auto se mueve fuera de un horario o zona permitida.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-300 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">history</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Historial</p>
                        <p class="text-xl font-bold text-slate-900">Historial de Rutas</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Revisa los recorridos realizados, paradas y velocidades de los últimos 30 días.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODO EMPRESA — 3 cards (siempre en DOM, visibilidad por CSS) -->
            <div class="@(!IsPersonalMode ? "grid" : "hidden") gap-6 md:grid-cols-3">
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-100 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">analytics</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Operaciones</p>
                        <p class="text-xl font-bold text-slate-900">Eficiencia Operativa</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Optimiza tiempos de entrega analizando las rutas actuales de cada unidad de tu flota.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-200 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">speed</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Control</p>
                        <p class="text-xl font-bold text-slate-900">Control de Velocidad</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Reduce riesgos y consumo de combustible monitoreando los excesos de velocidad.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-300 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                    <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                    <div class="relative z-10 p-8 flex flex-col h-full">
                        <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                            <span class="material-symbols-outlined text-3xl">groups</span>
                        </div>
                        <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Personal</p>
                        <p class="text-xl font-bold text-slate-900">Gestión de Personal</p>
                        <div class="mt-auto pt-6">
                            <div class="card-body">
                                <p class="text-sm text-slate-500 leading-relaxed">Monitorea el cumplimiento de itinerarios y zonas de trabajo asignadas a tus conductores.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Detailed Functionalites Section -->
    <section id="funcionalidades" class="py-24 bg-slate-50 relative overflow-hidden">
        <div class="mx-auto max-w-7xl px-6">
            <div class="text-center mb-16 scroll-animate">
                <h2 class="text-3xl font-extrabold text-slate-900 md:text-4xl mb-6">Poder en cada detalle</h2>
                <p class="mx-auto max-w-2xl text-slate-600">Tecnología de punta diseñada para darte visibilidad total en todo momento.</p>
            </div>
            <div class="grid gap-12 md:grid-cols-3">
                <div class="flex flex-col items-center text-center scroll-animate delay-100">
                    <div class="mb-6 rounded-full bg-white p-4 shadow-lg">
                        <span class="material-symbols-outlined text-4xl text-primary font-bold">timer</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Tiempo Real</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Actualizaciones constantes cada 10 segundos directamente en el mapa. Sin retrasos, sin dudas.</p>
                </div>
                <div class="flex flex-col items-center text-center scroll-animate delay-200">
                    <div class="mb-6 rounded-full bg-white p-4 shadow-lg">
                        <span class="material-symbols-outlined text-4xl text-primary font-bold">map</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Historial de Viajes</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Visualiza el recorrido exacto, las paradas realizadas y el tiempo en cada punto de interés.</p>
                </div>
                <div class="flex flex-col items-center text-center scroll-animate delay-300">
                    <div class="mb-6 rounded-full bg-white p-4 shadow-lg">
                        <span class="material-symbols-outlined text-4xl text-primary font-bold">bolt</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Alertas Inteligentes</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Configura geocercas y recibe notificaciones push instantáneas si una unidad entra o sale de ellas.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Map Preview Block -->
    <section class="py-24 bg-white relative">
        <div class="mx-auto max-w-7xl px-6">
            <div class="relative rounded-3xl overflow-hidden border border-slate-200 shadow-2xl bg-white scroll-animate">
                <div class="flex flex-col lg:flex-row divide-y lg:divide-y-0 lg:divide-x divide-slate-200">
                    <div class="lg:w-1/3 p-8">
                        <div class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-600 mb-6">En movimiento</div>
                        <h2 class="text-3xl font-extrabold text-slate-900 mb-4 tracking-tight">Tu centro de mando siempre disponible.</h2>
                        <p class="text-slate-600 mb-8 leading-relaxed">Accede desde tu computadora o lleva el control en tu celular con nuestra aplicación nativa altamente optimizada.</p>
                        <div class="space-y-4">
                            <div class="flex items-center gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100 transition-colors hover:border-primary/20">
                                <span class="material-symbols-outlined text-primary font-bold">smartphone</span>
                                <div class="text-sm">
                                    <p class="font-bold text-slate-900 text-sm">App Móvil Nativa</p>
                                    <p class="text-slate-500 text-xs">iOS y Android</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 rounded-xl bg-slate-50 border border-slate-100 transition-colors hover:border-primary/20">
                                <span class="material-symbols-outlined text-primary font-bold">cloud</span>
                                <div class="text-sm">
                                    <p class="font-bold text-slate-900 text-sm">Plataforma Web</p>
                                    <p class="text-slate-500 text-xs">Sin instalaciones complejas</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-2/3 h-[500px] relative bg-slate-100 overflow-hidden">
                        <div class="absolute inset-0 bg-slate-200">
                            <div class="w-full h-full opacity-40" style="background-image: radial-gradient(#1364ed 1px, transparent 1px); background-size: 30px 30px;"></div>
                        </div>
                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10">
                            <div class="relative">
                                <div class="absolute inset-0 h-10 w-10 rounded-full bg-primary/30 animate-ping"></div>
                                <div class="h-10 w-10 bg-primary rounded-full flex items-center justify-center text-white shadow-xl border-2 border-white relative z-10">
                                    <span class="material-symbols-outlined text-xl">local_shipping</span>
                                </div>
                                <div class="absolute top-12 left-1/2 -translate-x-1/2 whitespace-nowrap bg-white rounded-lg px-3 py-1.5 shadow-lg border border-slate-100">
                                    <p class="text-[10px] font-bold text-slate-900 leading-none mb-1">Unidad #402</p>
                                    <p class="text-[8px] text-green-500 font-bold leading-none uppercase">En ruta - 65 km/h</p>
                                </div>
                            </div>
                        </div>
                        <div class="absolute top-4 right-4 flex flex-col gap-2">
                            <button class="h-10 w-10 bg-white rounded-lg shadow-md flex items-center justify-center text-slate-600 hover:text-primary"><span class="material-symbols-outlined">add</span></button>
                            <button class="h-10 w-10 bg-white rounded-lg shadow-md flex items-center justify-center text-slate-600 hover:text-primary"><span class="material-symbols-outlined">remove</span></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA Section -->
    <section class="py-24 bg-primary relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#ffffff_0.5px,transparent_0.5px)] [background-size:24px_24px] opacity-10"></div>
        <div class="mx-auto max-w-4xl px-6 relative z-10 text-center scroll-animate">
            <h2 class="text-3xl font-extrabold text-white md:text-5xl mb-8 leading-tight">
                ¿Aún tienes dudas de dónde se encuentra tu vehículo justo ahora?
            </h2>
            <button @onclick='() => NavigationManager.NavigateTo("/signup")' class="rounded-full bg-white px-12 py-5 text-lg font-bold text-primary shadow-xl transition-all hover:bg-slate-50 hover:scale-105 active:scale-95 group relative overflow-hidden">
                <span class="relative z-10">Empezar ahora gratis</span>
                <div class="absolute inset-0 -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] bg-gradient-to-r from-transparent via-primary/5 to-transparent z-0"></div>
            </button>

            <p class="mt-6 text-blue-100 font-medium opacity-80 italic">Únete a la evolución de la logística en México.</p>
        </div>
    </section>
</div>

@code {
    private bool IsPersonalMode { get; set; } = true;

    private void SetMode(bool isPersonal)
    {
        IsPersonalMode = isPersonal;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await JS.InvokeVoidAsync("initializeScrollAnimations");
        }
    }
}