@page "/mantenimiento"
<PageTitle>Mantenimiento Preventivo Vehicular | Spider Fleet</PageTitle>
<HeadContent>
    <meta name="description" content="Gestiona el mantenimiento preventivo de tu flota con alertas automáticas, inspecciones fotográficas y calendario de servicios. Prolonga la vida de tus unidades. Spider Fleet México." />
    <link rel="canonical" href="https://spiderfleet.mx/mantenimiento" />
    <meta property="og:title" content="Mantenimiento Preventivo Vehicular | Spider Fleet" />
    <meta property="og:description" content="Alertas automáticas, inspecciones fotográficas y calendario de servicios para tu flota." />
    <meta property="og:url" content="https://spiderfleet.mx/mantenimiento" />
</HeadContent>
<style>
    .feature-card {
        min-height: 260px;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    border-color 0.4s ease;
    }
    .feature-card:hover {
        transform: translateY(-6px);
    }

    .feature-card .card-body {
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        opacity: 1;
        transform: translateY(0);
    }

    @@media (min-width: 768px) and (hover: hover) and (pointer: fine) {
        .feature-card .card-body {
            opacity: 0;
            transform: translateY(16px);
        }
        .feature-card:hover .card-body {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .feature-card .card-top-line {
        opacity: 0;
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .feature-card:hover .card-top-line {
        opacity: 1;
    }

    .feature-card .card-icon-b {
        background-color: #eff6ff;
        color: #2563eb;
        transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    color 0.4s ease,
                    transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .feature-card:hover .card-icon-b {
        transform: scale(1.1);
    }
</style>
@inject IJSRuntime JS
@inject NavigationManager NavigationManager


<div class="bg-white">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-20 pb-16 md:pt-32 md:pb-32">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[400px] h-[400px] bg-blue-400/5 rounded-full blur-3xl"></div>

        <div class="mx-auto max-w-7xl px-6 relative z-10 text-center">
            <div class="inline-flex items-center rounded-full border border-blue-500/20 bg-blue-50 px-4 py-1.5 text-sm font-semibold text-primary mb-8 scroll-animate">
                <span class="mr-2 h-2 w-2 rounded-full bg-primary animate-pulse"></span>
                Gestión Preventiva
            </div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-7xl mb-6 scroll-animate delay-100">
                No esperes a que algo falle.<br /><span class="text-primary">Anticípate.</span>
            </h1>
            <p class="mx-auto max-w-2xl text-lg text-slate-600 md:text-xl leading-relaxed mb-10 scroll-animate delay-200">
                Registra cada mantenimiento, recibe recordatorios automáticos y documenta el estado real de tu unidad con fotos e inspecciones detalladas. Todo en un solo lugar.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 scroll-animate delay-300">
                <button @onclick='() => NavigationManager.NavigateTo("/signup")' class="w-full sm:w-auto rounded-full bg-primary px-10 py-4 text-base font-bold text-white shadow-lg shadow-primary/25 transition-all hover:bg-blue-600 hover:scale-105 active:scale-95 group relative overflow-hidden">
                    <span class="relative z-10">Empieza Gratis Ahora</span>
                    <div class="absolute inset-0 -translate-x-full group-hover:animate-[shimmer_1s_infinite] bg-gradient-to-r from-transparent via-white/20 to-transparent z-0"></div>
                </button>
            </div>

        </div>
    </section>

    <!-- Toggle Section -->
    <section class="py-16 bg-slate-50">
        <div class="mx-auto max-w-7xl px-6">
            <div class="flex justify-center mb-16 scroll-animate">
                <div class="bg-slate-100 p-1.5 rounded-full flex relative isolate border border-slate-200 shadow-inner w-full max-w-[340px]">
                    <div class="absolute left-1.5 top-1.5 bottom-1.5 w-[calc(50%-6px)] bg-white rounded-full shadow transition-all duration-300 ease-in-out z-0 border border-slate-200" style="transform: translateX(@(IsPersonalMode ? "0" : "100%"));"></div>
                    <button class="flex-1 relative z-10 py-2.5 rounded-full text-sm transition-colors duration-300 text-center @(IsPersonalMode ? "text-primary font-bold" : "text-slate-500 font-semibold hover:text-slate-800")" @onclick="() => SetMode(true)">
                        Uso Personal
                    </button>
                    <button class="flex-1 relative z-10 py-2.5 rounded-full text-sm transition-colors duration-300 text-center @(IsPersonalMode ? "text-slate-500 font-semibold hover:text-slate-800" : "text-primary font-bold")" @onclick="() => SetMode(false)">
                        Para Flotas
                    </button>
                </div>
            </div>

            <div class="flex-col gap-16 @(IsPersonalMode ? "flex" : "hidden")">
                <div class="grid gap-6 md:grid-cols-3">
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                        <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                        <div class="relative z-10 p-8 flex flex-col h-full">
                            <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                                <span class="material-symbols-outlined text-3xl">history</span>
                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Registro</p>
                            <p class="text-xl font-bold text-slate-900">Bitácora Personal</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
                                    <p class="text-sm text-slate-500 leading-relaxed">Mantén el historial de servicios de tu vehículo siempre a la mano y aumenta su valor de reventa.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-100 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                        <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                        <div class="relative z-10 p-8 flex flex-col h-full">
                            <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                                <span class="material-symbols-outlined text-3xl">notifications_active</span>
                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Recordatorios</p>
                            <p class="text-xl font-bold text-slate-900">Avisos de Servicio</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
                                    <p class="text-sm text-slate-500 leading-relaxed">Olvídate de revisar el kilometraje. Te avisamos cuándo toca cambio de aceite, frenos o afinación.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-200 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
