                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Funcionalidades Detalle Personal *@
                <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-24 scroll-animate delay-300">
                    <div class="md:w-1/2">
                        <div class="inline-flex items-center gap-2 text-primary font-bold mb-4 uppercase tracking-widest text-sm">
                            <span class="h-px w-8 bg-primary"></span>
                            Orden y Control
                        </div>
                        <h2 class="text-3xl font-extrabold text-slate-900 md:text-5xl mb-6 leading-tight">Registro de mantenimientos detallado</h2>
                        <p class="text-slate-600 text-lg mb-8 leading-relaxed">
                            Llevamos el concepto de "bitácora" a otro nivel. Registra fecha, costo, taller, kilometraje y adjunta archivos para tener el control total del ciclo de vida de tu vehículo.
                        </p>
                        <div class="flex items-start gap-4 p-4 rounded-2xl bg-blue-50 border border-blue-100">
                            <span class="material-symbols-outlined text-primary mt-1">info</span>
                            <p class="text-sm text-blue-900 leading-relaxed">Ideal para deducibilidad de impuestos y para demostrar un historial impecable al vender.</p>
                        </div>
                    </div>
                    <div class="md:w-1/2 relative">
                        <div class="relative z-10 rounded-3xl border border-white/60 bg-white/40 backdrop-blur-md shadow-2xl p-6">
                            <div class="flex items-center justify-between mb-8 border-b border-slate-100/50 pb-4">
                                <h4 class="font-bold text-slate-900">Bitácora de Unidad Particular</h4>
                                <span class="text-xs text-slate-500 font-medium">Últ. actualización: Hoy 10:24 AM</span>
                            </div>
                            <div class="space-y-4">
                                <div class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 border border-slate-100">
                                    <div class="h-10 w-10 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-xl">oil_barrel</span>
                                    </div>
                                    <div class="flex-1">
                                        <div class="text-sm font-bold text-slate-900">Cambio de Aceite (Sintético)</div>
                                        <div class="text-[10px] text-slate-500">Completado • 45,000 KM</div>
                                    </div>
                                    <div class="text-sm font-bold text-slate-400">$1,450.00</div>
                                </div>
                                <div class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 border border-slate-100">
                                    <div class="h-10 w-10 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                                        <span class="material-symbols-outlined text-xl">tire_repair</span>
                                    </div>
                                    <div class="flex-1">
                                        <div class="text-sm font-bold text-slate-900">Rotación de Neumáticos</div>
                                        <div class="text-[10px] text-slate-500">Próximo • 15 Abr 2026</div>
                                    </div>
                                    <span class="material-symbols-outlined text-slate-300">more_vert</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODO FLOTA -->
            <div class="flex-col gap-16 @(!IsPersonalMode ? "flex" : "hidden")">
                <div class="grid gap-6 md:grid-cols-3">
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                        <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                        <div class="relative z-10 p-8 flex flex-col h-full">
                            <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                                <span class="material-symbols-outlined text-3xl">dashboard_customize</span>
                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Panel</p>
                            <p class="text-xl font-bold text-slate-900">Control de Flota</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
                                    <p class="text-sm text-slate-500 leading-relaxed">Gestiona los periodos de servicio de 10 o 100 unidades desde un solo panel centralizado.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-100 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                        <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                        <div class="relative z-10 p-8 flex flex-col h-full">
                            <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                                <span class="material-symbols-outlined text-3xl">engineering</span>
                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Correctivo</p>
                            <p class="text-xl font-bold text-slate-900">Mantenimiento Correctivo</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
                                    <p class="text-sm text-slate-500 leading-relaxed">Reduce el tiempo de inactividad de tus unidades críticas con un sistema de alertas proactivas.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="feature-card relative rounded-2xl bg-white cursor-pointer scroll-animate delay-200 border border-slate-200 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 overflow-hidden">
                        <div class="card-top-line absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/60 to-transparent rounded-t-2xl"></div>
                        <div class="relative z-10 p-8 flex flex-col h-full">
                            <div class="card-icon-b mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl">
                                <span class="material-symbols-outlined text-3xl">fact_check</span>
                            </div>
                            <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">Normativo</p>
                            <p class="text-xl font-bold text-slate-900">Cumplimiento Normativo</p>
                            <div class="mt-auto pt-6">
                                <div class="card-body">
                                    <p class="text-sm text-slate-500 leading-relaxed">Inspecciones digitales diarias para asegurar que cada unidad opera bajo los estándares de seguridad.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Funcionalidades Detalle Flota (Z-Pattern) *@
                <div class="flex flex-col md:flex-row-reverse items-center gap-12 lg:gap-24 scroll-animate delay-100">
                    <div class="md:w-1/2">
                        <div class="inline-flex items-center gap-2 text-primary font-bold mb-4 uppercase tracking-widest text-sm">
                            <span class="h-px w-8 bg-primary"></span>
                            Paz Mental
                        </div>
                        <h2 class="text-3xl font-extrabold text-slate-900 md:text-5xl mb-6 leading-tight">Recordatorios automáticos inteligentes</h2>
                        <p class="text-slate-600 text-lg mb-8 leading-relaxed">
                            No necesitas abrir la aplicación para saber qué sigue. Spider Fleet te enviará notificaciones push o correos antes de que un servicio venza, basado en tiempo o kilometraje acumulado.
                        </p>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-4 rounded-xl bg-slate-50 border border-slate-100 text-center">
                                <div class="text-2xl font-bold text-primary mb-1">98%</div>
                                <div class="text-[10px] font-bold text-slate-500 uppercase">Reducción de olvidos</div>
                            </div>
                            <div class="p-4 rounded-xl bg-slate-50 border border-slate-100 text-center">
                                <div class="text-2xl font-bold text-primary mb-1">15%</div>
                                <div class="text-[10px] font-bold text-slate-500 uppercase">Ahorro preventivo</div>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="rounded-3xl border border-slate-200 bg-white p-8 text-slate-900 shadow-2xl relative overflow-hidden group">
                           <div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/5 rounded-full blur-3xl transition-transform group-hover:scale-150 duration-700"></div>
                           <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-50 text-primary">
                               <span class="material-symbols-outlined">schedule</span>
                           </div>
                           <h4 class="text-xl font-bold mb-4 italic text-slate-900">"Tu Ford Transit requiere servicio en 250 KM"</h4>
                           <p class="text-slate-600 text-sm leading-relaxed mb-8">Notificación generada automáticamente al detectar el odómetro actualizado vía GPS.</p>
                           <button class="w-full rounded-full border border-slate-200 bg-slate-50 py-3 text-sm font-bold text-slate-700 hover:bg-slate-100 hover:border-primary/20 hover:text-primary transition-all">Configurar Alerta</button>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-24 scroll-animate delay-200">
                    <div class="md:w-1/2">
                        <div class="inline-flex items-center gap-2 text-primary font-bold mb-4 uppercase tracking-widest text-sm">
                            <span class="h-px w-8 bg-primary"></span>
                            Evidencia Visual
                        </div>
                        <h2 class="text-3xl font-extrabold text-slate-900 md:text-5xl mb-6 leading-tight">Inspecciones con fotos en tiempo real</h2>
                        <p class="text-slate-600 text-lg mb-8 leading-relaxed">
                            Elimina las hojas de papel. Realiza inspecciones visuales desde el móvil, marca fallas mecánicas y documenta el estado físico con fotografías fechadas y geolocalizadas.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3 font-medium text-slate-800">
                                <span class="material-symbols-outlined text-primary">photo_library</span>
                                Galería de daños históricos
                            </li>
                            <li class="flex items-center gap-3 font-medium text-slate-800">
                                <span class="material-symbols-outlined text-primary">qr_code_scanner</span>
                                Vinculación rápida por unidad
                            </li>
                        </ul>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative space-y-4">
                            <div class="rounded-3xl border border-white/60 bg-white/40 backdrop-blur-md shadow-xl overflow-hidden p-6">
                                <div class="flex items-center gap-4 mb-6">
                                    <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-blue-50 text-primary">
                                        <span class="material-symbols-outlined">checklist</span>
                                    </div>
                                    <h4 class="font-bold text-slate-900">Inspección de Flota</h4>
                                </div>
                                <div class="grid grid-cols-2 gap-3 mb-6">
                                    <div class="aspect-square rounded-2xl bg-slate-100 flex items-center justify-center border-2 border-dashed border-slate-200">
                                        <span class="material-symbols-outlined text-3xl text-slate-300">add_a_photo</span>
                                    </div>
                                    <div class="aspect-square rounded-2xl bg-slate-200 overflow-hidden relative border border-slate-200">
                                        <img src="Assets/Inspeccion.jpg" class="w-full h-full object-cover" width="300" height="300" alt="Inspección fotográfica de daño" />
                                        <div class="absolute bottom-2 left-2 bg-red-500 text-white text-[8px] font-bold px-1.5 py-0.5 rounded-full uppercase">Daño detectado</div>
                                    </div>
                                </div>
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm font-medium text-slate-600">Luces delanteras</span>
                                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm font-medium text-slate-600">Nivel de combustible</span>
                                        <span class="material-symbols-outlined text-amber-500">warning</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-primary text-white relative overflow-hidden text-center mx-6 my-12 rounded-[2.5rem] md:mx-auto md:max-w-7xl">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-indigo-900 -z-10"></div>
        <div class="absolute inset-0 z-0 bg-grid-white/[0.05]"></div>
        <div class="mx-auto max-w-4xl px-6 relative z-10 scroll-animate">
            <h2 class="text-3xl font-extrabold md:text-5xl mb-8 leading-tight">
                ¿Cuánto te cuesta hoy tener una unidad fuera de servicio por falta de mantenimiento?
            </h2>
            <p class="mx-auto max-w-2xl text-blue-100 text-lg mb-10">
                Ahorra preventivamente y mantén el control total de tu inversión con las herramientas de Spider Fleet.
            </p>
            <button @onclick='() => NavigationManager.NavigateTo("/signup")' class="rounded-full bg-white px-12 py-5 text-lg font-bold text-primary shadow-xl transition-all hover:bg-slate-50 hover:scale-105 active:scale-95">
                Empezar ahora gratis
            </button>

        </div>
    </section>
</div>

@code {
    private bool IsPersonalMode { get; set; } = true;

    private async Task SetMode(bool isPersonal)
    {
        IsPersonalMode = isPersonal;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("initScrollAnimations");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(150);
            await JS.InvokeVoidAsync("initScrollAnimations");
        }
    }
}